<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.StatisticsActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_height"
        app:layout_constraintTop_toTopOf="parent"
        android:background="@color/dark_pastel_green"
        android:minHeight="?attr/actionBarSize"
        android:theme="?attr/actionBarTheme" />

    <TextView
        android:id="@+id/tv_toolbar_custom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="@id/toolbar"
        app:layout_constraintLeft_toLeftOf="@id/toolbar"
        app:layout_constraintRight_toRightOf="@id/toolbar"
        android:textColor="@color/toolbar_header_color"
        android:textSize="@dimen/toolbar_header_size"
        android:textStyle="bold"
        android:text="@string/statistics" />

    <Button
        android:id="@+id/buttonBack"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/bbutton_layout_height"
        android:layout_marginStart="@dimen/bbutton_margin_start"
        android:layout_marginBottom="@dimen/bbutton_margin_bottom"
        android:layout_marginTop="@dimen/bbutton_margin_top"
        android:text="@string/bbutton_text"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <androidx.cardview.widget.CardView
        android:id="@+id/StatisticsCardView"
        android:layout_width="match_parent"
        android:layout_height="@dimen/card_height"
        android:layout_marginTop="@dimen/card_margin"
        android:layout_marginLeft="@dimen/page_margin"
        android:layout_marginRight="@dimen/page_margin"
        android:layout_marginBottom="@dimen/page_margin"

        app:cardBackgroundColor="@color/card_color"
        app:cardCornerRadius="@dimen/card_corner_radius"
        app:cardElevation="@dimen/card_elevation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/constractCardLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_constraintBottom_toTopOf="@+id/image"
            app:layout_constraintTop_toTopOf="@+id/image">


            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/constraintLayoutUpper"
                android:layout_width="match_parent"
                android:layout_height="85dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@id/constraintLayoutLower">

                <ImageView
                    android:id="@+id/image"
                    android:layout_width="80dp"
                    android:layout_height="match_parent"

                    android:layout_marginStart="18dp"
                    android:layout_marginEnd="20dp"

                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toTopOf="parent"


                    app:srcCompat="@drawable/together_heroes" />


                <TextView
                    android:id="@+id/name"
                    android:layout_width="match_parent"
                    android:layout_height="29dp"

                    android:layout_marginLeft="@dimen/stat_header_left_margin_from_icon"
                    android:layout_marginTop="10dp"

                    android:text="Overall"
                    android:textSize="25sp"
                    android:textStyle="bold"
                    android:textAlignment="center"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toEndOf="@id/image"/>

            </androidx.constraintlayout.widget.ConstraintLayout>


            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/constraintLayoutLower"
                android:layout_width="match_parent"
                android:layout_height="60dp"

                app:layout_constraintBottom_toBottomOf="parent"
                >
                <ScrollView
                    android:id="@+id/statisticsScrollView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    tools:layout_editor_absoluteX="-16dp"
                    tools:layout_editor_absoluteY="-16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/upperLinear"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/missions"
                            android:layout_width="@dimen/stat_element_header_width"
                            android:layout_height="wrap_content"
                            android:text="Total missions:"
                            android:textAlignment="center"
                            android:textStyle="bold" />


                        <TextView
                            android:id="@+id/wins"
                            android:layout_width="@dimen/stat_element_header_width"
                            android:layout_height="wrap_content"
                            android:text="Total wins:"
                            android:textAlignment="center"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/minsTotal"
                            android:layout_width="@dimen/stat_element_header_width"
                            android:layout_height="wrap_content"
                            android:text="Total sim. mins:"
                            android:textAlignment="center"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/trainingTotal"
                            android:layout_width="@dimen/stat_element_header_width"
                            android:layout_height="wrap_content"
                            android:text="Total sim. times:"
                            android:textAlignment="center"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/experience"
                            android:layout_width="@dimen/stat_element_header_width"
                            android:layout_height="wrap_content"
                            android:text="Total avg. sim. time:"
                            android:textAlignment="center"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/lowerLinear"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:layout_constraintBottom_toBottomOf="@id/upperLinear"

                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/missions2"
                            android:layout_width="@dimen/stat_element_header_width"
                            android:layout_height="wrap_content"
                            android:text="Total missions:"
                            android:textAlignment="center"
                            android:textStyle="bold" />


                        <TextView
                            android:id="@+id/wins2"
                            android:layout_width="@dimen/stat_element_header_width"
                            android:layout_height="wrap_content"
                            android:text="Total wins:"
                            android:textAlignment="center"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/minsTotal2"
                            android:layout_width="@dimen/stat_element_header_width"
                            android:layout_height="wrap_content"
                            android:text="Total sim. mins:"
                            android:textAlignment="center"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/trainingTotal2"
                            android:layout_width="@dimen/stat_element_header_width"
                            android:layout_height="wrap_content"
                            android:text="Total sim. times:"
                            android:textAlignment="center"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/trainingAvg2"
                            android:layout_width="@dimen/stat_element_header_width"
                            android:layout_height="wrap_content"
                            android:text="Total avg. sim. time:"
                            android:textAlignment="center"
                            android:textStyle="bold" />
                    </LinearLayout>

                    </LinearLayout>

                </ScrollView>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"

        app:layout_constraintTop_toBottomOf="@id/toolbar"
        android:layout_marginTop="@dimen/card_height"
        android:text="Lutemons"
        android:textAlignment="center"
        android:textColor="@color/toolbar_header_color"
        android:textSize="@dimen/toolbar_header_size"
        android:textStyle="bold"
         />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/stat_recycler_view"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="8dp"

        android:layout_marginBottom="@dimen/page_margin"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/buttonCharts"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:layout_marginTop="@dimen/page_margin"
        android:layout_marginBottom="@dimen/page_margin"
        android:layout_marginLeft="@dimen/page_margin"
        android:layout_marginRight="@dimen/page_margin"
        android:text="View Charts"
        app:layout_constraintBottom_toBottomOf="parent"/>






</androidx.constraintlayout.widget.ConstraintLayout>